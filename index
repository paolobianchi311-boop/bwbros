<script>
'use strict';
if(!CanvasRenderingContext2D.prototype.roundRect){CanvasRenderingContext2D.prototype.roundRect=function(x,y,w,h,r){r=Math.min(r,w/2,h/2);this.beginPath();this.moveTo(x+r,y);this.lineTo(x+w-r,y);this.quadraticCurveTo(x+w,y,x+w,y+r);this.lineTo(x+w,y+h-r);this.quadraticCurveTo(x+w,y+h,x+w-r,y+h);this.lineTo(x+r,y+h);this.quadraticCurveTo(x,y+h,x,y+h-r);this.lineTo(x,y+r);this.quadraticCurveTo(x,y,x+r,y);this.closePath();};}
function shade(hex,a){let c=hex.replace('#','');if(c.length===3)c=c.split('').map(x=>x+x).join('');let r=parseInt(c.slice(0,2),16),g=parseInt(c.slice(2,4),16),b=parseInt(c.slice(4,6),16);r=Math.max(0,Math.min(255,r+a));g=Math.max(0,Math.min(255,g+a));b=Math.max(0,Math.min(255,b+a));return'#'+[r,g,b].map(x=>x.toString(16).padStart(2,'0')).join('');}

const IS_TOUCH=('ontouchstart' in window)||(navigator.maxTouchPoints>0);
let currentScreen='intro',fsTried=false;
if(IS_TOUCH)document.body.addEventListener('touchmove',e=>e.preventDefault(),{passive:false});
function goFullscreen(){if(fsTried||!IS_TOUCH)return;fsTried=true;const el=document.documentElement,req=el.requestFullscreen||el.webkitRequestFullscreen||el.msRequestFullscreen;if(!req)return;try{const p=req.call(el);if(p&&p.catch)p.catch(()=>{});}catch(e){}}
document.addEventListener('fullscreenchange',()=>setTimeout(resizeGame,150));
function getVW(){return window.visualViewport?window.visualViewport.width:window.innerWidth;}
function getVH(){return window.visualViewport?window.visualViewport.height:window.innerHeight;}
const SCREEN_H={intro:700,select:600,game:542};
function getContentH(){if(currentScreen==='game')return SCREEN_H.game;if(currentScreen==='select'){const el=document.getElementById('selScreen');const h=el?el.offsetHeight:0;return h>200?h:SCREEN_H.select;}return SCREEN_H.intro;}
function resizeGame(){
  const vw=getVW(), vh=getVH();
  const wrap=document.getElementById('scaleWrap');
  if(vw<760 && vh>vw && currentScreen!=='game'){
    document.body.classList.add('mobileUI');
    wrap.style.transform='none';wrap.style.left='0px';wrap.style.top='0px';
    return;
  }
  document.body.classList.remove('mobileUI');
  const gW=1100, gH=getContentH();
  const scale = Math.min(vw/gW, vh/gH);
  const sW = gW * scale, sH = gH * scale;
  const lo = Math.max(0, (vw - sW) / 2);
  let to = Math.max(0, (vh - sH) / 2);
  const isPortrait = vh > vw;
  if(isPortrait && currentScreen === 'game') { to = Math.max(10, vh * 0.05); }
  wrap.style.transform=`scale(${scale})`;
  wrap.style.left=lo+'px';
  wrap.style.top=to+'px';
}
window.addEventListener('resize',resizeGame);
window.addEventListener('orientationchange',()=>setTimeout(resizeGame,250));
if(window.visualViewport){window.visualViewport.addEventListener('resize',resizeGame);window.visualViewport.addEventListener('scroll',resizeGame);}
if(document.fonts&&document.fonts.ready)document.fonts.ready.then(resizeGame);

const FAVI=new Image();let FAVI_OK=false;
FAVI.onload=()=>{FAVI_OK=true;};FAVI.onerror=()=>{if(FAVI.src.indexOf('sv/favicon')>-1)FAVI.src='https://gobuff.com/favicon.png';};FAVI.src='https://gobuff.com/sv/favicon.png';
function logoCanvas(ctx,cx,cy,sz){ctx.save();const r=sz*.14;ctx.fillStyle='#7B1A1A';ctx.beginPath();ctx.roundRect(cx-sz/2,cy-sz/2,sz,sz,r);ctx.fill();const ig=ctx.createRadialGradient(cx,cy-sz*.1,0,cx,cy,sz*.7);ig.addColorStop(0,'rgba(255,80,30,.22)');ig.addColorStop(1,'transparent');ctx.fillStyle=ig;ctx.beginPath();ctx.roundRect(cx-sz/2,cy-sz/2,sz,sz,r);ctx.fill();if(FAVI_OK&&FAVI.naturalWidth>0){const p=sz*.14,is=sz-p*2;ctx.drawImage(FAVI,cx-is/2,cy-is/2,is,is);}else{ctx.fillStyle='#FF6B00';ctx.font=`bold ${sz*.34}px 'Bebas Neue',Arial`;ctx.textAlign='center';ctx.textBaseline='middle';ctx.fillText('BW',cx,cy);ctx.textBaseline='alphabetic';}ctx.restore();}

const IC=document.getElementById('introCanvas'),IX=IC.getContext('2d');
const IW=1100,IH=700;
(()=>{const r=2;IC.width=IW*r;IC.height=IH*r;IC.style.width=IW+'px';IC.style.height=IH+'px';IX.scale(r,r);})();
let introFrame=0;
const iStars=[];for(let i=0;i<75;i++)iStars.push({x:Math.random()*IW,y:Math.random()*IH*.55,r:Math.random()*1.4+.4,tw:Math.random()*Math.PI*2,sp:Math.random()*.05+.02});
const iBalls=[];for(let i=0;i<3;i++)iBalls.push({x:200+i*360,y:160+Math.random()*120,vx:(Math.random()-.5)*4.5,vy:0,r:17+i*5,rot:Math.random()*6,vr:(Math.random()-.5)*.2});
const iConfCols=['#FF6B00','#f1c40f','#2ecc71','#e74c3c','#3498db','#ffffff'];
const iConf=[];for(let i=0;i<54;i++)iConf.push({x:Math.random()*IW,y:Math.random()*IH,vx:(Math.random()-.5)*1.3,vy:Math.random()*1.6+.5,sz:Math.random()*6+3,rot:Math.random()*Math.PI*2,vr:(Math.random()-.5)*.22,col:iConfCols[Math.floor(Math.random()*iConfCols.length)]});
function animateIntro(){
  introFrame++;IX.clearRect(0,0,IW,IH);
  const sky=IX.createLinearGradient(0,0,0,IH);sky.addColorStop(0,'#0a0420');sky.addColorStop(.45,'#1e0824');sky.addColorStop(.75,'#330a12');sky.addColorStop(1,'#1a0500');
  IX.fillStyle=sky;IX.fillRect(0,0,IW,IH);
  iStars.forEach(s=>{IX.globalAlpha=.35+Math.abs(Math.sin(introFrame*s.sp+s.tw))*.6;IX.fillStyle='#fff';IX.beginPath();IX.arc(s.x,s.y,s.r,0,Math.PI*2);IX.fill();});IX.globalAlpha=1;
  const beams=[{x:90,a:1.18},{x:300,a:1.05},{x:IW-300,a:Math.PI-1.05},{x:IW-90,a:Math.PI-1.18}];
  beams.forEach((b,i)=>{const ang=b.a+Math.sin(introFrame*.01+i*1.3)*.05,len=620,spread=72;const ex=Math.cos(ang)*len,ey=Math.sin(ang)*len;IX.save();IX.translate(b.x,-10);const g=IX.createLinearGradient(0,0,ex,ey);g.addColorStop(0,'rgba(255,244,210,.17)');g.addColorStop(1,'rgba(255,210,140,0)');IX.fillStyle=g;IX.beginPath();IX.moveTo(-12,0);IX.lineTo(ex-spread,ey);IX.lineTo(ex+spread,ey);IX.lineTo(12,0);IX.closePath();IX.fill();IX.fillStyle='rgba(255,250,225,.25)';IX.beginPath();IX.arc(0,0,13,0,Math.PI*2);IX.fill();IX.fillStyle='rgba(255,250,225,.95)';IX.beginPath();IX.arc(0,0,6,0,Math.PI*2);IX.fill();IX.restore();});
  const groundY=IH-95;
  iBalls.forEach(bl=>{bl.vy+=.32;bl.x+=bl.vx;bl.y+=bl.vy;bl.rot+=bl.vr;if(bl.y+bl.r>groundY){bl.y=groundY-bl.r;bl.vy*=-.82;bl.vr=bl.vx*.05;}if(bl.x-bl.r<0){bl.x=bl.r;bl.vx*=-1;}if(bl.x+bl.r>IW){bl.x=IW-bl.r;bl.vx*=-1;}const sq=Math.max(.25,1-(groundY-bl.y-bl.r)/220);IX.fillStyle='rgba(0,0,0,.32)';IX.beginPath();IX.ellipse(bl.x,groundY+4,bl.r*sq,bl.r*.26*sq,0,0,Math.PI*2);IX.fill();IX.save();IX.translate(bl.x,bl.y);IX.rotate(bl.rot);const bg=IX.createRadialGradient(-bl.r*.3,-bl.r*.35,bl.r*.1,0,0,bl.r);bg.addColorStop(0,'#fff');bg.addColorStop(1,'#c4c4c4');IX.fillStyle=bg;IX.beginPath();IX.arc(0,0,bl.r,0,Math.PI*2);IX.fill();IX.fillStyle='#1a1a1a';IX.beginPath();for(let i=0;i<5;i++){const a=i*Math.PI*2/5-Math.PI/2;IX.lineTo(Math.cos(a)*bl.r*.33,Math.sin(a)*bl.r*.33);}IX.closePath();IX.fill();for(let i=0;i<5;i++){const a=i*Math.PI*2/5-Math.PI/2+Math.PI/5;IX.save();IX.rotate(a);IX.beginPath();IX.ellipse(0,bl.r*.74,bl.r*.19,bl.r*.15,0,0,Math.PI*2);IX.fill();IX.restore();}IX.strokeStyle='rgba(0,0,0,.3)';IX.lineWidth=.8;IX.beginPath();IX.arc(0,0,bl.r,0,Math.PI*2);IX.stroke();IX.fillStyle='rgba(255,255,255,.4)';IX.beginPath();IX.ellipse(-bl.r*.34,-bl.r*.38,bl.r*.22,bl.r*.13,-.6,0,Math.PI*2);IX.fill();IX.restore();});
  iConf.forEach(c=>{c.x+=c.vx;c.y+=c.vy;c.rot+=c.vr;if(c.y>IH+12){c.y=-12;c.x=Math.random()*IW;}if(c.x<-12)c.x=IW+12;if(c.x>IW+12)c.x=-12;IX.save();IX.translate(c.x,c.y);IX.rotate(c.rot);IX.globalAlpha=.78;IX.fillStyle=c.col;IX.fillRect(-c.sz/2,-c.sz/2,c.sz,c.sz*.6);IX.restore();});IX.globalAlpha=1;
  const grd=IX.createLinearGradient(0,groundY,0,IH);grd.addColorStop(0,'#1c601c');grd.addColorStop(1,'#0a2e0a');IX.fillStyle=grd;IX.fillRect(0,groundY,IW,IH-groundY);
