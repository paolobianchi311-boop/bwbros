<html lang="es"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
<title>Socazone Buffalo Bros 🦬</title>
<link rel="icon" href="https://gobuff.com/sv/favicon.png">
<style>
@import url('https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&family=Bebas+Neue&display=swap');
*{margin:0;padding:0;box-sizing:border-box}
html,body{overflow:hidden;overscroll-behavior:none}
body{background:#0a0000;width:100vw;height:100vh;height:100dvh;font-family:'Oswald',sans-serif;touch-action:none;-webkit-tap-highlight-color:transparent}
#scaleWrap{position:fixed;top:0;left:0;transform-origin:top left;will-change:transform}
#introScreen{width:1100px;position:relative;overflow:hidden;cursor:pointer}
#introCanvas{display:block;touch-action:none}
.intro-content{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:flex-start;padding-top:30px;pointer-events:none}
.intro-logo-box{width:165px;height:165px;border-radius:18px;background:#7B1A1A;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;gap:2px;box-shadow:0 0 60px rgba(200,40,40,.7),0 0 110px rgba(255,107,0,.22),0 10px 28px rgba(0,0,0,.8)}
.intro-logo-box img{width:100px;height:100px;object-fit:contain;filter:drop-shadow(0 2px 8px rgba(0,0,0,.5))}
.intro-logo-box .lb-txt{font-size:29px;color:#fff;font-family:'Bebas Neue',sans-serif;letter-spacing:2px}.intro-logo-box .lb-sub{font-size:8.5px;letter-spacing:3px;color:rgba(255,255,255,.85)}
.intro-title{font-family:'Bebas Neue',sans-serif;font-size:62px;color:#FF6B00;letter-spacing:7px;text-align:center;margin-top:14px;line-height:1;text-shadow:0 0 40px rgba(255,107,0,.7);animation:titleIn .8s ease-out forwards}
.intro-tagline{font-size:12.5px;color:rgba(255,210,130,.88);letter-spacing:6px;margin-top:6px;text-align:center;animation:fadeUp .6s .3s ease-out forwards;opacity:0}
.intro-divider{width:400px;height:1px;background:linear-gradient(90deg,transparent,#FF6B00,rgba(255,107,0,.3),transparent);margin:15px auto;animation:fadeUp .6s .5s ease-out forwards;opacity:0}
.intro-synopsis{width:820px;background:rgba(0,0,0,.7);border:1px solid rgba(255,107,0,.32);border-radius:12px;padding:18px 28px;text-align:center;animation:fadeUp .8s .6s ease-out forwards;opacity:0;backdrop-filter:blur(4px)}
.intro-synopsis .syn-lead{font-family:'Bebas Neue',sans-serif;font-size:22px;color:#FF6B00;letter-spacing:3px;display:block;margin-bottom:9px}
.intro-synopsis p{color:rgba(255,255,255,.9);font-size:14px;line-height:1.7}
.intro-synopsis .syn-cta{color:#FF6B00;font-weight:700;font-size:14.5px;display:block;margin-top:11px;letter-spacing:2px}
.intro-feats{display:flex;gap:14px;margin-top:14px;animation:fadeUp .8s .8s ease-out forwards;opacity:0}
.intro-feat{background:rgba(255,107,0,.12);border:1px solid rgba(255,107,0,.34);border-radius:9px;padding:9px 13px;text-align:center;min-width:130px}
.intro-feat .fi{font-size:22px;display:block;margin-bottom:3px}
.intro-feat span{font-size:9.5px;color:rgba(255,255,255,.7);letter-spacing:1px;display:block}
.intro-press{font-family:'Bebas Neue',sans-serif;font-size:25px;letter-spacing:7px;margin-top:16px;animation:blink 1s infinite,fadeUp .6s 1s ease-out forwards;opacity:0;color:#FF6B00}
.intro-footer{font-size:9.5px;color:rgba(255,150,60,.5);letter-spacing:3px;margin-top:8px;animation:fadeUp .6s 1.1s ease-out forwards;opacity:0}
@keyframes titleIn{from{opacity:0;transform:scale(.82) translateY(-10px)}to{opacity:1;transform:scale(1) translateY(0)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.25}}
#selScreen{display:none;width:1100px;background:linear-gradient(160deg,#0d0300,#1a0700,#0d0300);border:2px solid #FF6B00;box-shadow:0 0 70px rgba(255,107,0,.28)}
.sel-header{background:linear-gradient(135deg,#150400,#250900);border-bottom:2px solid rgba(255,107,0,.45);padding:14px 22px;display:flex;align-items:center;gap:14px}
#btnBackIntro{background:rgba(255,107,0,.14);border:1px solid rgba(255,107,0,.45);color:#FF6B00;font-size:22px;width:46px;height:46px;border-radius:9px;cursor:pointer;flex-shrink:0;display:flex;align-items:center;justify-content:center;transition:all .15s}
#btnBackIntro:active{transform:scale(.92);background:rgba(255,107,0,.3)}
.sel-logo-box{width:78px;height:78px;border-radius:9px;background:#7B1A1A;flex-shrink:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:1px}
.sel-logo-box img{width:50px;height:50px;object-fit:contain}
.sel-logo-box .lb-txt{font-size:17px;color:#fff;font-family:'Bebas Neue',sans-serif;letter-spacing:1px}
.sel-logo-box .lb-sub{font-size:6.5px;color:rgba(255,255,255,.8);letter-spacing:1.5px}
.sel-header-text h1{font-family:'Bebas Neue',sans-serif;font-size:38px;color:#FF6B00;letter-spacing:4px;line-height:1}
.sel-header-text h2{font-size:12px;color:rgba(255,255,255,.6);letter-spacing:4px;margin-top:4px}
.sel-header-text p{font-size:9.5px;color:rgba(255,140,50,.6);letter-spacing:3px;margin-top:5px;border-top:1px solid rgba(255,107,0,.16);padding-top:5px}
.sel-body{padding:16px 20px;max-width:940px;margin:0 auto}
.char-grid{display:flex;flex-wrap:wrap;justify-content:center;gap:14px;margin-bottom:16px}
.char-card{background:rgba(255,107,0,.03);border:1.5px solid rgba(255,107,0,.18);border-radius:12px;padding:14px 10px;cursor:pointer;transition:all .2s;text-align:center;position:relative;overflow:hidden;flex:1 1 calc(25% - 14px);min-width:160px}
.char-card:hover{border-color:#FF6B00;transform:translateY(-3px);box-shadow:0 8px 20px rgba(255,107,0,.2)}
.char-card.selected{border-color:#FF6B00;background:rgba(255,107,0,.07);box-shadow:0 0 18px rgba(255,107,0,.3)}
.char-card.selected .chk{display:block}
.chk{display:none;position:absolute;top:7px;right:9px;color:#FF6B00;font-size:18px;font-weight:900}
.char-card canvas{display:block;margin:0 auto 7px;border-radius:6px;background:rgba(0,0,0,.22)}
.c-flag{font-size:28px;display:block;margin-bottom:3px}
.c-name{color:#fff;font-size:15px;font-weight:700;letter-spacing:2px;display:block}
.c-stat{color:#FF6B00;font-size:11px;display:block;margin-top:4px}
.c-desc{color:rgba(255,255,255,.45);font-size:9px;display:block;margin-top:2px}
.pips{display:flex;align-items:center;gap:2px;justify-content:center;margin-top:4px}
.pips label{color:rgba(255,255,255,.42);font-size:8px;width:26px;text-align:right;margin-right:3px}
.pip{width:13px;height:4px;border-radius:2px}
.sel-footer{display:flex;align-items:center;gap:16px;padding-top:12px;border-top:1px solid rgba(255,107,0,.16)}
.play-btn{flex:1;background:linear-gradient(135deg,#FF6B00,#c84d00);color:#fff;border:none;padding:16px 0;font-family:'Bebas Neue',sans-serif;font-size:28px;letter-spacing:5px;cursor:pointer;border-radius:10px;transition:all .2s;box-shadow:0 6px 16px rgba(255,107,0,.4)}
.play-btn:hover{transform:translateY(-2px)}
.sel-foot-txt{color:rgba(255,140,50,.55);font-size:9.5px;letter-spacing:2px;text-align:right;line-height:1.8}
#gameWrap{display:none;position:relative;width:1100px}
#hud{background:linear-gradient(90deg,#060100,#0f0400,#1a0600,#0f0400,#060100);border:2px solid #FF6B00;border-bottom:none;padding:0 14px;display:flex;align-items:stretch;height:58px}
.hud-brand{display:flex;align-items:center;gap:8px;padding-right:14px;border-right:1px solid rgba(255,107,0,.28);cursor:pointer}
.hud-logo-sm{width:38px;height:38px;border-radius:7px;background:#7B1A1A;flex-shrink:0;display:flex;align-items:center;justify-content:center}
.hud-logo-sm img{width:28px;height:28px;object-fit:contain}
.hud-brand-text .t1{font-family:'Bebas Neue',sans-serif;font-size:19px;color:#FF6B00;letter-spacing:2px;display:block;line-height:1.1}
.hud-brand-text .t2{font-size:9px;color:rgba(255,255,255,.45);letter-spacing:1px;display:block}
.hud-char{display:flex;align-items:center;gap:8px;padding:0 14px;border-right:1px solid rgba(255,107,0,.28)}
.hud-char .flag{font-size:24px}.hud-char b{color:#FF6B00;font-size:13px;display:block;line-height:1.2}.hud-char small{color:rgba(255,255,255,.45);font-size:9px}
.hud-stats{display:flex;align-items:center;flex:1;justify-content:space-evenly}
.hstat{text-align:center;padding:0 6px;border-right:1px solid rgba(255,107,0,.1)}.hstat:last-child{border:none}
.hstat b{color:#FF6B00;font-size:19px;display:block;line-height:1.2;font-family:'Bebas Neue',sans-serif;text-shadow:0 2px 4px rgba(0,0,0,0.8)}
.hstat span{font-size:9px;color:rgba(255,255,255,.48);letter-spacing:1px}
.hud-right{display:flex;align-items:center;padding-left:12px;border-left:1px solid rgba(255,107,0,.28)}
#muteBtn,#pauseBtn{background:rgba(255,107,0,.14);border:1px solid rgba(255,107,0,.38);color:#FF6B00;font-size:14px;padding:5px 9px;cursor:pointer;border-radius:5px}
#pauseBtn{margin-right:7px}
canvas{display:block;border:2px solid #FF6B00;box-shadow:0 0 40px rgba(255,107,0,.18);touch-action:none}
#escHint{position:absolute;bottom:4px;right:8px;font-size:8px;color:rgba(255,150,60,.4);pointer-events:none}
#touchCtrl { display:none; position:fixed; inset:0; z-index:1000; pointer-events:none; }
.t-btn { position:absolute; border-radius:50%; display:flex; flex-direction:column; align-items:center; justify-content:center; pointer-events:all; user-select:none; touch-action:none; -webkit-tap-highlight-color:transparent; transition:transform .06s, opacity .08s; cursor:pointer; backdrop-filter:blur(4px); opacity:0.55; }
.t-btn .bico { display:block; line-height:1; pointer-events:none; font-size: clamp(28px, 7vw, 42px); }
.t-btn .blbl { display:block; font-weight:600; pointer-events:none; margin-top:2px; font-size: clamp(10px, 2.5vw, 14px); }
.t-btn:active, .t-btn.pressed { transform:scale(.86)!important; opacity:1; }
#tLeft { left:4vw; bottom:6vh; width:clamp(70px, 20vw, 110px); height:clamp(70px, 20vw, 110px); background:rgba(255,107,0,.3); border:3px solid rgba(255,107,0,.6); box-shadow:0 4px 14px rgba(0,0,0,.6); }
#tRight { left:calc(4vw + clamp(70px, 20vw, 110px) + 3vw); bottom:6vh; width:clamp(70px, 20vw, 110px); height:clamp(70px, 20vw, 110px); background:rgba(255,107,0,.3); border:3px solid rgba(255,107,0,.6); box-shadow:0 4px 14px rgba(0,0,0,.6); }
#tRun { right:calc(4vw + clamp(80px, 22vw, 120px) + 3vw); bottom:6vh; width:clamp(60px, 17vw, 90px); height:clamp(60px, 17vw, 90px); background:rgba(60,60,60,.6); border:3px solid rgba(200,200,200,.6); box-shadow:0 4px 14px rgba(0,0,0,.6); }
#tJump { right:4vw; bottom:6vh; width:clamp(80px, 22vw, 120px); height:clamp(80px, 22vw, 120px); background:rgba(30,160,80,.5); border:3px solid rgba(46,204,113,.8); box-shadow:0 4px 14px rgba(0,0,0,.6); }
#tLeft .bico, #tRight .bico { color:#fff; }
#tLeft .blbl, #tRight .blbl { color:rgba(255,255,255,.8); }
#tRun .bico { color:rgba(255,255,255,.9); }
#tRun .blbl { color:rgba(255,255,255,.7); }
#tJump .bico { color:#2ecc71; }
#tJump .blbl { color:rgba(46,204,113,.9); }
#tRun.sprint-on { background:rgba(255,80,0,.6); border-color:rgba(255,160,0,.9); box-shadow:0 0 22px rgba(255,120,0,.7); opacity:1; }
#tRun.sprint-on .bico { color:#ffd700; }
#tRun.sprint-on .blbl { color:#ffc200; font-weight:700; }
#finishModal{display:none;position:fixed;inset:0;z-index:6000;background:radial-gradient(circle at 50% 28%,#2a0606,#0a0000 72%);overflow:auto;-webkit-overflow-scrolling:touch;padding:12px}
#finishModal.show{display:flex;align-items:flex-start;justify-content:center}
.fm-inner{width:100%;max-width:min(540px,95vw);margin:auto;padding:6px 0 28px;animation:fmPop .5s cubic-bezier(.2,1.2,.4,1) both}
@keyframes fmPop{from{opacity:0;transform:scale(.85) translateY(20px)}to{opacity:1;transform:scale(1) translateY(0)}}
.fm-summary{text-align:center;margin-bottom:14px}
.fm-summary h2{font-family:'Bebas Neue',sans-serif;font-size:clamp(30px,7.5vw,42px);color:#FF6B00;letter-spacing:3px;line-height:1;text-shadow:0 0 24px rgba(255,107,0,.5)}
.fm-summary .fm-sub{color:rgba(255,200,120,.7);font-size:clamp(10px,2.5vw,12px);letter-spacing:2px;margin-top:5px}
.fm-topstats{display:flex;justify-content:center;gap:8px;margin:12px 0}
.fm-topstats>div{flex:1;background:rgba(255,107,0,.1);border:1px solid rgba(255,107,0,.3);border-radius:10px;padding:10px 4px;text-align:center}
.fm-topstats b{display:block;font-family:'Bebas Neue',sans-serif;font-size:clamp(22px,6vw,30px);color:#fff;line-height:1.1}
.fm-topstats span{font-size:clamp(8px,2.2vw,10px);color:rgba(255,255,255,.45);letter-spacing:1px}
#fmStep1{background:rgba(255,255,255,.04);border:1px solid rgba(255,107,0,.25);border-radius:14px;padding:18px}
#fmStep1 label{display:block;color:rgba(255,255,255,.85);font-size:clamp(13px,3.4vw,15px);margin-bottom:12px;line-height:1.55}
#fmEmail{width:100%;padding:15px 14px;border-radius:10px;border:2px solid rgba(255,107,0,.4);background:rgba(0,0,0,.5);color:#fff;font-family:'Oswald',sans-serif;font-size:clamp(15px,4vw,17px);outline:none}
#fmEmail::placeholder{color:rgba(255,255,255,.3)}
#fmEmail:focus{border-color:#FF6B00;box-shadow:0 0 14px rgba(255,107,0,.3)}
#fmError{color:#ff7a5c;font-size:clamp(11px,3vw,13px);min-height:14px;margin-top:6px}
#fmGenerate{width:100%;margin-top:12px;padding:16px 0;border:none;border-radius:10px;background:linear-gradient(135deg,#FF6B00,#c84d00);color:#fff;font-family:'Bebas Neue',sans-serif;font-size:clamp(22px,5.5vw,26px);letter-spacing:3px;cursor:pointer;box-shadow:0 6px 16px rgba(255,107,0,.4)}
#fmStep2{display:none}
.fm-ticket{background:#fff;border-radius:16px;overflow:hidden;box-shadow:0 8px 32px rgba(0,0,0,.7);margin-bottom:14px;position:relative}
.fmt-head{background:linear-gradient(135deg,#7B1A1A,#a02020);padding:14px 16px;display:flex;align-items:center;gap:11px}
.fmt-head img{width:clamp(36px,9vw,46px);height:clamp(36px,9vw,46px);border-radius:8px;border:2px solid rgba(255,255,255,.25)}
.fmt-head-text .fht1{font-family:'Bebas Neue',sans-serif;font-size:clamp(18px,5vw,24px);color:#fff;letter-spacing:2px;display:block;line-height:1.1}
.fmt-head-text .fht2{font-size:clamp(9px,2.4vw,12px);color:rgba(255,200,100,.75);letter-spacing:2px;display:block}
.fmt-qrzone{background:#fff;padding:16px 14px 10px;text-align:center;position:relative}
.fmt-qrzone::after,.fmt-qrzone::before{content:'';position:absolute;width:24px;height:24px;border-radius:50%;background:#0a0000;top:50%;transform:translateY(-50%)}
.fmt-qrzone::before{left:-12px}.fmt-qrzone::after{right:-12px}
#fmQRCanvas{display:block;margin:0 auto;border-radius:8px;width:clamp(250px,74vw,360px);height:clamp(250px,74vw,360px)}
.fmt-scan-label{font-size:clamp(11px,3vw,14px);color:rgba(123,26,26,.7);letter-spacing:1px;margin-top:10px;display:block;font-weight:600}
.fmt-sep{border:none;border-top:2.5px dashed rgba(123,26,26,.2);margin:0}
.fmt-data{background:#fdf5ee;padding:12px 18px 14px}
.fmt-data-title{font-size:clamp(8px,2.2vw,10px);color:rgba(123,26,26,.5);letter-spacing:3px;text-align:center;margin-bottom:10px;text-transform:uppercase}
.fmt-row{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid rgba(123,26,26,.08)}
.fmt-row:last-child{border:none}
.fmt-lbl{font-size:clamp(9.5px,2.6vw,12px);color:rgba(80,20,10,.6);letter-spacing:1px;text-transform:uppercase;flex-shrink:0}
.fmt-val{font-size:clamp(13px,3.2vw,16px);font-weight:600;color:#2a0606;text-align:right;word-break:break-all;max-width:62%}
.fmt-val.pts{color:#c84d00;font-family:'Bebas Neue',sans-serif;font-size:clamp(17px,4.5vw,22px)}
.fmt-val.coins{color:#b8860b}
.fmt-token{display:flex;align-items:center;justify-content:center;gap:6px;padding:6px 0 4px;margin-top:2px;border-top:1px solid rgba(123,26,26,.1)}
.fmt-token .tk-badge{background:#7B1A1A;color:#fff;font-family:'Bebas Neue',sans-serif;font-size:clamp(13px,3.5vw,16px);letter-spacing:2px;padding:3px 9px;border-radius:4px}
.fmt-token .tk-label{font-size:clamp(8px,2.2vw,10px);color:rgba(123,26,26,.5);letter-spacing:1.5px}
.fmt-foot{background:#7B1A1A;padding:10px 16px;display:flex;align-items:center;justify-content:space-between}
.fmt-foot-left{font-family:'Bebas Neue',sans-serif;font-size:clamp(13px,3.5vw,16px);color:#fff;letter-spacing:2px}
.fmt-foot-right{font-size:clamp(8px,2.2vw,10px);color:rgba(255,200,100,.6);letter-spacing:1.5px}
.fmt-qr-loading{width:clamp(250px,74vw,360px);height:clamp(250px,74vw,360px);margin:0 auto;background:#f5f0eb;border-radius:8px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;border:2px dashed rgba(123,26,26,.2)}
.fmt-qr-loading .qrl-spin{font-size:32px;animation:spin .8s linear infinite}
.fmt-qr-loading .qrl-txt{font-size:clamp(10px,2.8vw,13px);color:rgba(123,26,26,.6);letter-spacing:1px}
@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
#fmRestart{width:100%;padding:16px 0;border:none;border-radius:12px;background:linear-gradient(135deg,#FF6B00,#c84d00);color:#fff;font-family:'Bebas Neue',sans-serif;font-size:clamp(22px,5.5vw,26px);letter-spacing:3px;cursor:pointer;box-shadow:0 6px 16px rgba(255,107,0,.4)}
.fm-foot-note{color:rgba(255,107,0,.4);font-size:clamp(8.5px,2.3vw,10px);letter-spacing:3px;text-align:center;margin-top:12px}
@media(min-width:700px){.fm-inner{max-width:600px}}
#lbModal{display:none;position:fixed;inset:0;z-index:6500;background:rgba(5,0,0,.93);align-items:center;justify-content:center;padding:20px;overflow:auto}
#lbModal.show{display:flex}
.lb-card{background:linear-gradient(160deg,#160500,#250a00);border:2px solid #FF6B00;border-radius:16px;padding:22px;width:100%;max-width:min(480px,94vw);box-shadow:0 0 50px rgba(255,107,0,.3);margin:auto}
.lb-card h2{font-family:'Bebas Neue',sans-serif;color:#FF6B00;font-size:clamp(26px,6.5vw,34px);letter-spacing:2px;text-align:center;margin-bottom:14px}
.lb-row{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:8px;margin-bottom:5px;background:rgba(255,107,0,.06);font-size:clamp(13px,3.6vw,16px);color:#fff}
.lb-row .rk{width:32px;font-size:clamp(15px,4vw,18px)}.lb-row .nm{flex:1;font-weight:600}.lb-row .pt{color:#f1c40f;font-weight:700}
.lb-row .evts{font-size:clamp(10px,2.5vw,12px); color:rgba(255,255,255,.6); margin-left: auto; text-align:right;}
.lb-empty{color:rgba(255,255,255,.4);text-align:center;padding:24px;font-size:clamp(13px,3.5vw,15px);line-height:1.6}
.lb-card button{width:100%;margin-top:8px;padding:14px;border:none;border-radius:10px;background:linear-gradient(135deg,#FF6B00,#c84d00);color:#fff;font-family:'Bebas Neue',sans-serif;font-size:clamp(18px,4.5vw,22px);letter-spacing:2px;cursor:pointer}
#lbClear{background:rgba(255,255,255,.07);color:rgba(255,255,255,.55);font-size:clamp(12px,3.2vw,14px)}
/* === MEJORAS MÓVIL === */
body.mobileUI #scaleWrap{position:static!important;transform:none!important;left:0!important;top:0!important;width:100vw}
@media(max-width:760px) and (orientation:portrait){
 body.mobileUI #introScreen{width:100vw;min-height:100dvh;display:flex;flex-direction:column}
