function buildSelect(){const grid=document.getElementById('charGrid');if(grid.children.length)return;CHARS.forEach((ch,i)=>{const card=document.createElement('div');card.className='char-card'+(i===0?' selected':'');card.id='card_'+ch.id;let pH='';ch.pips.forEach(p=>{pH+='<div class="pips"><label>'+p[1]+'</label>';for(let k=0;k<5;k++)pH+='<div class="pip" style="background:'+(k<p[0]?'#FF6B00':'rgba(255,255,255,.1)')+'"></div>';pH+='</div>';});card.innerHTML='<div class="chk">✓</div><canvas id="prev_'+ch.id+'" width="180" height="150" style="width:90px;height:75px"></canvas><span class="c-flag">'+ch.flag+'</span><span class="c-name">'+ch.name+'</span><span class="c-stat">'+ch.stat+'</span><span class="c-desc">'+(ch.desc||'')+'</span>'+pH;card.addEventListener('click',()=>{SEL=ch;document.querySelectorAll('.char-card').forEach(c=>c.classList.remove('selected'));card.classList.add('selected');});grid.appendChild(card);const cv=document.getElementById('prev_'+ch.id);let t=Math.random()*100;setInterval(()=>{if(cv)_pd(cv,ch,t++);},50);});resizeGame();}
function _pd(cv,ch,t){const c=cv.getContext('2d'),S=cv.width/74;c.setTransform(S,0,0,S,0,0);const cx=37,bob=Math.sin(t*.06)*2.5,y=4+bob,x=cx-15;c.clearRect(0,0,74,62);if(document.getElementById('card_'+ch.id)?.classList.contains('selected')){const g=c.createRadialGradient(cx,30,0,cx,30,36);g.addColorStop(0,'rgba(255,107,0,.12)');g.addColorStop(1,'transparent');c.fillStyle=g;c.fillRect(0,0,74,62);}const lg=Math.sin(t*.18)*6,ay=Math.sin(t*.18)*3;c.fillStyle='rgba(0,0,0,.2)';c.beginPath();c.ellipse(cx,y+52,12,4,0,0,Math.PI*2);c.fill();c.fillStyle=ch.sh;c.beginPath();c.roundRect(x+4,y+27,8,15+lg,2);c.fill();c.beginPath();c.roundRect(x+13,y+27,8,15-lg,2);c.fill();c.fillStyle='#ecf0f1';c.fillRect(x+2,y+41+lg,12,4);c.fillRect(x+11,y+41-lg,12,4);const jg=c.createLinearGradient(0,y+12,0,y+29);jg.addColorStop(0,shade(ch.j,18));jg.addColorStop(1,shade(ch.j,-22));c.fillStyle=jg;c.beginPath();c.roundRect(x+2,y+12,25,17,3);c.fill();c.fillStyle=ch.st;c.font='bold 8px Oswald,Arial';c.textAlign='center';c.fillText('10',cx,y+23);c.lineCap='round';[[-1,ay],[1,-ay]].forEach(([s,o])=>{const sX=cx+s*11,sY=y+15,eX=cx+s*16,eY=y+21+o,hX=cx+s*13,hY=y+27+o;c.strokeStyle=ch.j;c.lineWidth=5;c.beginPath();c.moveTo(sX,sY);c.lineTo(eX,eY);c.stroke();c.strokeStyle=ch.sk;c.lineWidth=4;c.beginPath();c.moveTo(eX,eY);c.lineTo(hX,hY);c.stroke();c.fillStyle=ch.sk;c.beginPath();c.arc(hX,hY,3,0,Math.PI*2);c.fill();});c.fillStyle=ch.sk;c.beginPath();c.arc(cx,y+6,9,0,Math.PI*2);c.fill();c.fillStyle=ch.hr;c.beginPath();c.arc(cx,y+4,9,Math.PI,0);c.fill();c.fillStyle='#fff';c.beginPath();c.arc(cx-3,y+5,2,0,Math.PI*2);c.fill();c.beginPath();c.arc(cx+3,y+5,2,0,Math.PI*2);c.fill();c.fillStyle='#000';c.beginPath();c.arc(cx-3,y+5,1,0,Math.PI*2);c.fill();c.beginPath();c.arc(cx+3,y+5,1,0,Math.PI*2);c.fill();}

resizeGame();animateIntro();gameLoop();
</script>
